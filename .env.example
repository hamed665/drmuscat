NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=DrKhaleej
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,ar
NEXT_PUBLIC_DEFAULT_COUNTRY=om
NEXT_PUBLIC_ALLOWED_PUBLIC_LOCALES=en,ar
NEXT_PUBLIC_ALLOWED_PUBLIC_COUNTRIES=om
NEXT_PUBLIC_ENABLE_INDEXING=false
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional public WhatsApp number. Use Oman local 8 digits or 968-prefixed international format.
NEXT_PUBLIC_DRKHALEEJ_WHATSAPP_NUMBER=
# Legacy fallback during DrMuscat -> DrKhaleej migration. Prefer NEXT_PUBLIC_DRKHALEEJ_WHATSAPP_NUMBER for new deployments.
NEXT_PUBLIC_DRMUSCAT_WHATSAPP_NUMBER=
# Server-only Supabase key. Never prefix with NEXT_PUBLIC and never expose to browsers.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Server-only feature flag for approved public FAQ CMS reads. Missing/false keeps code-based FAQ fallback.
DRMUSCAT_PUBLIC_FAQ_CMS_ENABLED=false
