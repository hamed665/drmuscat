      "input": {
        "controlledPublishContractReady": true,
        "executorInfrastructureReady": true,
        "persistenceSchemaReady": true,
        "entityId": "entity-001",
        "actorId": "admin-001",
        "idempotencyKey": "publish:entity-001:v7",
        "expectedVersion": "v7",
        "currentVersion": "v7",
        "currentStateComplete": true,
        "desiredRoutePresent": true,
        "desiredProjectionPresent": true
