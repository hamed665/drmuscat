{
  "name": "drmuscat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "routes:check": "node scripts/routes-check.mjs",
    "env:check": "node scripts/env-check.mjs",
    "db:check-cli": "node scripts/db/check-supabase-cli.mjs",
    "db:validate:migrations": "node scripts/db/validate-migrations-taxrlsa.mjs",
    "db:validate:seeds": "node scripts/db/validate-seeds.mjs",
    "db:types": "pnpm db:check-cli && supabase gen types typescript --local > supabase/types/database.types.ts",
    "db:reset": "pnpm db:check-cli && supabase db reset",
    "test:db:rls": "pnpm db:validate:migrations && node scripts/db/test-rls-static-taxrlsa.mjs",
    "test:db:seed": "pnpm db:validate:seeds && node scripts/db/test-seed-static.mjs",
    "seo:check": "node scripts/seo-check.mjs",
    "test": "pnpm test:unit",
    "test:unit": "vitest run",
    "test:landing:public-gate": "node scripts/db/test-landing-public-gate-static.mjs",
    "test:landing:runtime:scaffold": "node scripts/db/test-landing-runtime-scaffold.mjs",
    "test:landing:runtime": "node scripts/db/test-landing-runtime.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "2.50.2",
    "next": "16.2.7",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@tailwindcss/postcss": "4.1.8",
    "@types/node": "22.15.30",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.7",
    "supabase": "^2.101.0",
    "tailwindcss": "4.1.8",
    "typescript": "5.9.3",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.22.0"
}
